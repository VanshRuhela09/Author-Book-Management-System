# Example environment variables for Author-Book-Management-System
# Copy this file to .env and set your values

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/AuthorBookDB
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=root
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true

JWT_SECRET=ThisIsAVerySecretKeyForJWTThatMustBeAtLeast256BitsLong!!
JWT_EXPIRATION_MS=86400000

SERVER_PORT=8081
LOGGING_FILE_NAME=application.log

# Swagger / OpenAPI (optional)
SPRINGDOC_API_DOCS_PATH=/v3/api-docs
SPRINGDOC_SWAGGER_UI_PATH=/swagger-ui.html
SPRINGDOC_SWAGGER_UI_OPERATIONS_SORTER=method

